<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="14dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- TOP ROW: avatar + name + delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Avatar -->
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="👤"
                android:textSize="22sp"
                android:gravity="center"
                android:background="@drawable/bg_avatar"
                android:layout_marginEnd="12dp" />

            <!-- Name + package -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPackage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="com.roblox.client"
                    android:textColor="@color/sub"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Status badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Idle"
                android:textColor="@color/sub"
                android:textSize="11sp"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="monospace" />

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/bg_chip_red"
                android:tint="@color/red"
                android:contentDescription="Hapus" />
        </LinearLayout>

        <!-- PS Link -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_mono"
            android:padding="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PS "
                android:textColor="@color/accent2"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvPsLink"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="https://..."
                android:textColor="@color/sub"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Action row: Manual Rejoin + Clone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManualRejoin"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="🔄 Rejoin"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                style="@style/BtnOutline" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClone"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="📋 Clone"
                android:textSize="12sp"
                style="@style/BtnOutline" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
